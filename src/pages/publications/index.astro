---
import PageLayout from '@/layouts/CommonPage.astro'
import { Collapse } from 'astro-pure/user'
import { publications, } from '@/pages/publications/data.astro'

const headings = publications.flatMap((group) => [
  {
    depth: 2,
    slug: `year-${group.year}`,
    text: group.year
  },
  ...group.items.map((pub) => ({
    depth: 3,
    slug: pub.slug,
    text: pub.title
  }))
])
---

<PageLayout title='Publications' {headings} comment>

  <div class='publication-list'>
    {
      publications.map((group) => (
        <section class='publication-year-section'>
          <h2 id={`year-${group.year}`} class='publication-year'>
            {group.year}
          </h2>

          <div class='publication-items'>
            {
              group.items.map((pub) => (
                <article class='publication-item'>
                  <div class='publication-top'>
                    <div class='publication-image'>
                      {pub.image ? (
                        <img src={pub.image} alt={pub.title} />
                      ) : (
                        <div class='publication-image-placeholder'>No Image</div>
                      )}
                    </div>

                    <div class='publication-meta'>
                      <h3 id={pub.slug} class='publication-title'>
                        {pub.title}
                      </h3>

                      {pub.authors.length <= 4 ? (
                        <div class='publication-authors'>
                          {pub.authors.map((author, index) => (
                            <>
                              {author === 'Zefei Xie' ? <strong>{author}</strong> : author}
                              {index < pub.authors.length - 1 ? ', ' : ''}
                            </>
                          ))}
                        </div>
                      ) : (
                        <Collapse
                          title={`${pub.authors.slice(0, 3).join(', ')} +${pub.authors.length - 3} more`}
                        >
                          <div class='publication-authors'>
                            {pub.authors.map((author, index) => (
                              <>
                                {author === 'Zefei Xie' ? <strong>{author}</strong> : author}
                                {index < pub.authors.length - 1 ? ', ' : ''}
                              </>
                            ))}
                          </div>
                        </Collapse>
                      )}

                      <div class='publication-venue'>{pub.venue}</div>

                      {pub.description && (
                        <div class='publication-description'>{pub.description}</div>
                      )}

                      <div class='publication-links'>
                        {pub.pdf && (
                          <a href={pub.pdf} target='_blank' rel='noopener noreferrer'>PDF</a>
                        )}
                        {pub.code && (
                          <a href={pub.code} target='_blank' rel='noopener noreferrer'>Code</a>
                        )}
                        {pub.doi && (
                          <a href={pub.doi} target='_blank' rel='noopener noreferrer'>DOI</a>
                        )}
                        {pub.bibtex && (
                          <a href={pub.bibtex} target='_blank' rel='noopener noreferrer'>BibTeX</a>
                        )}
                        {pub.online && (
                          <a href={pub.bibtex} target='_blank' rel='noopener noreferrer'>Online</a>
                        )}
                      </div>
                    </div>
                  </div>

                  {pub.abstract && (
                    <div class='publication-abstract'>
                      <Collapse title='Abstract'>
                        <p>{pub.abstract}</p>
                      </Collapse>
                    </div>
                  )}
                </article>
              ))
            }
          </div>
        </section>
      ))
    }
  </div>

</PageLayout>

<style>
    .publication-list {
        display: flex;
        flex-direction: column;
        gap: 0rem;
        margin-top: 0rem;
    }

    .publication-year-section {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .publication-year {
        font-size: 1.2rem;
        font-weight: 700;
        margin: 0;
    }

    .publication-items {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
    }

    .publication-item {
        padding-bottom: 1.5rem;
        border-bottom: 1px solid hsl(var(--border));
        animation: fadeUp 0.45s ease both;
    }

    .publication-top {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 1.25rem;
        align-items: start;
    }

    .publication-image img,
    .publication-image-placeholder {
        display: block;
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        border-radius: 1rem;
        border: 1px solid hsl(var(--border));
        background: hsl(var(--muted));
    }

    .publication-image-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        color: hsl(var(--muted-foreground));
        font-size: 0.9rem;
    }

    .publication-meta {
        min-width: 0;
    }

    .publication-title {
        display: block;
        font-size: 1.08rem;
        font-weight: 600;
        line-height: 1.5;
        margin: 0 0 0.35rem 0 !important;
        scroll-margin-top: 6rem;
    }

    .publication-authors {
        color: hsl(var(--muted-foreground));
        font-size: 0.95rem;
        line-height: 1.7;
    }

    .publication-venue {
        margin-top: 0.25rem;
        font-size: 0.95rem;
        font-style: italic;
        color: hsl(var(--muted-foreground));
    }

    .publication-description {
        margin-top: 0.55rem;
        font-size: 0.95rem;
        line-height: 1.7;
    }

    .publication-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 0.85rem;
    }

    .publication-links a {
        display: inline-block;
        padding: 0.15rem 0.55rem;
        border: 1px solid hsl(var(--border));
        border-radius: 9999px;
        font-size: 0.82rem;
        text-decoration: none;
        color: hsl(var(--muted-foreground));
        transition: all 0.2s ease;
    }

    .publication-links a:hover {
        color: hsl(var(--foreground));
        border-color: hsl(var(--foreground) / 0.3);
        background: hsl(var(--muted));
    }

    .publication-abstract {
        margin-top: 1rem;
    }

    .publication-bottom {
        margin-top: 2rem;
    }

    .old-projects {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .old-project-item {
        padding: 0.75rem 0;
        border-bottom: 1px solid hsl(var(--border));
    }

    .old-project-item:last-child {
        border-bottom: none;
    }

    .old-project-title {
        font-weight: 600;
        margin-bottom: 0.25rem;
    }

    .old-project-description {
        color: hsl(var(--muted-foreground));
        line-height: 1.6;
        font-size: 0.95rem;
    }

    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 900px) {
        .publication-top {
            grid-template-columns: 1fr;
        }

        .publication-image {
            max-width: 320px;
        }
    }
</style>